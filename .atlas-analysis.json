  "keyFeatures": [
    "Bidirectional packet translation between Bedrock and Java protocols",
    "Multi-platform support: Spigot, BungeeCord, Velocity, Fabric, NeoForge, Standalone, ViaProxy",
    "Extension/plugin API with event bus for custom integrations",
    "Custom item and block definitions for Bedrock clients",
    "Resource pack support with URL-based delivery",
    "Online and offline authentication mode support",
    "Camera API for controlling Bedrock client perspective",
    "Floodgate integration for cross-platform account handling"
  ],
